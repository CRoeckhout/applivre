{
  "name": "applivre",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "APP_VARIANT=development expo start --device",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "APP_VARIANT=development expo run:android --device",
    "ios": "APP_VARIANT=development expo run:ios --device",
    "build:ios": "expo run:ios --device --configuration Release",
    "build:android": "expo run:android --device --variant release",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/caveat": "^0.4.2",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/lora": "^0.4.2",
    "@expo-google-fonts/orbitron": "^0.4.2",
    "@expo-google-fonts/space-mono": "^0.4.2",
    "@expo-google-fonts/unifrakturmaguntia": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.104.0",
    "@tanstack/react-query": "^5.99.2",
    "applivre-live-activity": "link:./modules/live-activity",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "fast-xml-parser": "^5.7.1",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-wheel-color-picker": "^1.3.1",
    "react-native-worklets": "0.5.1",
    "tslib": "^2.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@bacons/apple-targets": "^4.0.6",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.17",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "private": true
}
